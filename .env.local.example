# ─────────────────────────────────────────────────────────────
# Bytescare Onboarding — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bytescare-onboarding

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email addresses ───────────────────────────────────────────
FROM_EMAIL=onboarding@bytescare.com          # Sender address for all outgoing emails
OPS_EMAIL=ops@bytescare.com                  # Operations team (receives ops requirements)
SALES_EMAIL=sales@bytescare.com              # Sales team (receives new application tickets)
SUPPORT_EMAIL=support@bytescare.com          # Support contact shown to customers

# ── PandaDoc ──────────────────────────────────────────────────
PANDADOC_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PANDADOC_SERVICE_AGREEMENT_TEMPLATE_ID=xxxxxxxxxxxxxxxxxxxx   # Template ID for SA
PANDADOC_LOA_TEMPLATE_ID=xxxxxxxxxxxxxxxxxxxx                 # Template ID for LOA

# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx   # From Razorpay dashboard > Webhooks

# ── Sales Portal ──────────────────────────────────────────────
SALES_PORTAL_PASSWORD=bytescare-sales-2026               # Plain password (stored hashed in DB)
SALES_JWT_SECRET=replace-with-64-char-random-string      # openssl rand -base64 64

# ── Application ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
CRON_SECRET=replace_with_random_secret_string
